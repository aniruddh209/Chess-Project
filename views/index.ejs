<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content="Play chess online in real-time with friends. A sleek, professional chess experience." />
    <title>Chess Play — Online Chess Game</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <meta name="google-site-verification" content="EuwlH4r5QJxM2uNRCi5DbRTz3t7SvJym6j1qb9EAPF8" />
  </head>
  <body>
    <!-- Ambient Background Glow -->
    <div class="ambient-glow ambient-glow-1"></div>
    <div class="ambient-glow ambient-glow-2"></div>
    <div class="ambient-glow ambient-glow-3"></div>
    <!-- ============================================================
         SCREEN 1: AUTH (Login / Signup)
         ============================================================ -->
    <div id="auth-screen" class="screen active-screen">
      <div class="auth-container">

        <!-- Left: Hero / Branding -->
        <div class="auth-hero">
          <div class="auth-hero-pieces">
            <span class="floating-piece fp-1">♔</span>
            <span class="floating-piece fp-2">♛</span>
            <span class="floating-piece fp-3">♜</span>
            <span class="floating-piece fp-4">♞</span>
            <span class="floating-piece fp-5">♝</span>
            <span class="floating-piece fp-6">♟</span>
          </div>
          <div class="auth-hero-content">
            <h1 class="auth-title">ChessPlay</h1>
            <p class="auth-tagline">Where strategy meets elegance</p>
            <div class="auth-features">
              <div class="auth-feat"><span class="auth-feat-icon">⚔️</span><span>Play with Friends</span></div>
              <div class="auth-feat"><span class="auth-feat-icon">🤖</span><span>Challenge AI</span></div>
              <div class="auth-feat"><span class="auth-feat-icon">📊</span><span>Track Your Stats</span></div>
              <div class="auth-feat"><span class="auth-feat-icon">🎨</span><span>Custom Board Themes</span></div>
            </div>
          </div>
        </div>

        <!-- Right: Auth Form -->
        <div class="auth-form-wrapper">
          <div class="auth-logo">
            <span class="logo-icon-large">♔</span>
          </div>

          <!-- Login Form -->
          <div id="login-form" class="auth-form glass-panel">
            <h2 class="auth-form-title">Welcome Back</h2>
            <div class="form-group">
              <label for="login-username">Username</label>
              <input type="text" id="login-username" placeholder="Username" autocomplete="username" maxlength="20" />
            </div>
            <div class="form-group">
              <label for="login-password">Password</label>
              <input type="password" id="login-password" placeholder="Password" autocomplete="current-password" />
            </div>
            <div id="login-error" class="auth-error" style="display:none;"></div>
            <button id="btn-login" class="btn btn-primary btn-full">Sign In</button>
            <p class="auth-switch">
              New here?
              <a href="#" id="show-signup">Create Account</a>
            </p>
          </div>

          <!-- Signup Form -->
          <div id="signup-form" class="auth-form glass-panel" style="display:none;">
            <h2 class="auth-form-title">Create Account</h2>
            <div class="form-group">
              <label for="signup-username">Username</label>
              <input type="text" id="signup-username" placeholder="Username" autocomplete="username" maxlength="20" />
            </div>
            <div class="form-group">
              <label for="signup-password">Password</label>
              <input type="password" id="signup-password" placeholder="Password" autocomplete="new-password" />
            </div>
            <div class="form-group">
              <label for="signup-confirm">Confirm Password</label>
              <input type="password" id="signup-confirm" placeholder="Confirm password" autocomplete="new-password" />
            </div>
            <div id="signup-error" class="auth-error" style="display:none;"></div>
            <button id="btn-signup" class="btn btn-primary btn-full">Create Account</button>
            <p class="auth-switch">
              Have an account?
              <a href="#" id="show-login">Sign In</a>
            </p>
          </div>

          <p class="auth-footer">Developed by Aniruddh Parmar</p>
        </div>

      </div>
    </div>

    <!-- ============================================================
         SCREEN 2: LOBBY (Create or Join Room)
         ============================================================ -->
    <div id="lobby-screen" class="screen">
      <div class="lobby-container">

        <!-- Lobby Header -->
        <div class="lobby-header">
          <div class="logo">
            <span class="logo-icon">♔</span>
            <span class="logo-text">ChessPlay</span>
          </div>
          <div class="lobby-user-info">
            <span class="lobby-greeting">Hello, <strong id="lobby-username"></strong></span>
            <button id="btn-profile" class="btn btn-secondary btn-small">👤 Profile</button>
            <button id="btn-logout" class="btn btn-secondary btn-small">Logout</button>
          </div>
        </div>

        <!-- Hero Section -->
        <div class="lobby-hero">
          <div class="hero-content">
            <h1 class="hero-title">Your Move Awaits</h1>
            <p class="hero-subtitle">Challenge friends or test your skills against AI. Pick your style and start playing.</p>
          </div>
          <div class="hero-features">
            <div class="hero-feat"><span class="feat-icon">⚔️</span><span>Multiplayer</span></div>
            <div class="hero-feat"><span class="feat-icon">🤖</span><span>AI Opponent</span></div>
            <div class="hero-feat"><span class="feat-icon">📊</span><span>Track Stats</span></div>
            <div class="hero-feat"><span class="feat-icon">🎨</span><span>Board Themes</span></div>
          </div>
        </div>

        <!-- Board Theme Selector -->
        <div class="theme-section">
          <h2 class="section-title">🎨 Choose Your Board</h2>
          <div class="theme-grid" id="theme-grid">
            <label class="theme-card">
              <input type="radio" name="board-theme" value="classic" checked />
              <div class="theme-preview">
                <div class="mini-board">
                  <div class="mini-sq" style="background:#f0d9b5;"></div>
                  <div class="mini-sq" style="background:#b58863;"></div>
                  <div class="mini-sq" style="background:#b58863;"></div>
                  <div class="mini-sq" style="background:#f0d9b5;"></div>
                </div>
              </div>
              <span class="theme-name">Classic Wood</span>
            </label>
            <label class="theme-card">
              <input type="radio" name="board-theme" value="emerald" />
              <div class="theme-preview">
                <div class="mini-board">
                  <div class="mini-sq" style="background:#eeeed2;"></div>
                  <div class="mini-sq" style="background:#769656;"></div>
                  <div class="mini-sq" style="background:#769656;"></div>
                  <div class="mini-sq" style="background:#eeeed2;"></div>
                </div>
              </div>
              <span class="theme-name">Emerald</span>
            </label>
            <label class="theme-card">
              <input type="radio" name="board-theme" value="ice" />
              <div class="theme-preview">
                <div class="mini-board">
                  <div class="mini-sq" style="background:#dee3e6;"></div>
                  <div class="mini-sq" style="background:#8ca2ad;"></div>
                  <div class="mini-sq" style="background:#8ca2ad;"></div>
                  <div class="mini-sq" style="background:#dee3e6;"></div>
                </div>
              </div>
              <span class="theme-name">Blue Ice</span>
            </label>
            <label class="theme-card">
              <input type="radio" name="board-theme" value="tournament" />
              <div class="theme-preview">
                <div class="mini-board">
                  <div class="mini-sq" style="background:#e8e0c8;"></div>
                  <div class="mini-sq" style="background:#3a7d44;"></div>
                  <div class="mini-sq" style="background:#3a7d44;"></div>
                  <div class="mini-sq" style="background:#e8e0c8;"></div>
                </div>
              </div>
              <span class="theme-name">Tournament</span>
            </label>
            <label class="theme-card">
              <input type="radio" name="board-theme" value="marble" />
              <div class="theme-preview">
                <div class="mini-board">
                  <div class="mini-sq" style="background:#f5f0e1;"></div>
                  <div class="mini-sq" style="background:#6e6658;"></div>
                  <div class="mini-sq" style="background:#6e6658;"></div>
                  <div class="mini-sq" style="background:#f5f0e1;"></div>
                </div>
              </div>
              <span class="theme-name">Marble</span>
            </label>
            <label class="theme-card">
              <input type="radio" name="board-theme" value="walnut" />
              <div class="theme-preview">
                <div class="mini-board">
                  <div class="mini-sq" style="background:#e6cba1;"></div>
                  <div class="mini-sq" style="background:#7b4e2a;"></div>
                  <div class="mini-sq" style="background:#7b4e2a;"></div>
                  <div class="mini-sq" style="background:#e6cba1;"></div>
                </div>
              </div>
              <span class="theme-name">Walnut</span>
            </label>
          </div>
        </div>

        <!-- Game Mode Cards -->
        <h2 class="section-title" style="margin-bottom:20px;">🎮 Start a Game</h2>
        <div class="lobby-cards">
          <!-- Create Room Card -->
          <div class="lobby-card glass-panel" id="card-create">
            <div class="lobby-card-icon">♔</div>
            <h2 class="lobby-card-title">Create Room</h2>
            <p class="lobby-card-desc">Start a new game and invite a friend</p>
            <div class="color-picker">
              <label class="color-option">
                <input type="radio" name="create-color" value="white" checked />
                <span class="color-swatch color-white">♔</span>
                <span>White</span>
              </label>
              <label class="color-option">
                <input type="radio" name="create-color" value="black" />
                <span class="color-swatch color-black">♚</span>
                <span>Black</span>
              </label>
              <label class="color-option">
                <input type="radio" name="create-color" value="random" />
                <span class="color-swatch color-random">🎲</span>
                <span>Random</span>
              </label>
            </div>
            <button id="btn-create-room" class="btn btn-primary btn-full">Create Room</button>
          </div>

          <!-- Join Room Card -->
          <div class="lobby-card glass-panel" id="card-join">
            <div class="lobby-card-icon">♚</div>
            <h2 class="lobby-card-title">Join Room</h2>
            <p class="lobby-card-desc">Enter your friend's room code to join</p>
            <div class="form-group">
              <input type="text" id="join-room-code" placeholder="Enter 6-letter code" maxlength="6" style="text-transform: uppercase; text-align: center; font-size: 20px; letter-spacing: 4px;" />
            </div>
            <div id="join-error" class="auth-error" style="display:none;"></div>
            <button id="btn-join-room" class="btn btn-primary btn-full">Join Room</button>
          </div>

          <!-- Play vs AI Card -->
          <div class="lobby-card glass-panel" id="card-ai">
            <div class="lobby-card-icon">🤖</div>
            <h2 class="lobby-card-title">Play vs AI</h2>
            <p class="lobby-card-desc">Challenge the computer at your level</p>
            <div class="ai-difficulty">
              <label class="diff-option">
                <input type="radio" name="ai-diff" value="easy" />
                <span class="diff-badge diff-easy">Easy</span>
              </label>
              <label class="diff-option">
                <input type="radio" name="ai-diff" value="medium" checked />
                <span class="diff-badge diff-medium">Medium</span>
              </label>
              <label class="diff-option">
                <input type="radio" name="ai-diff" value="hard" />
                <span class="diff-badge diff-hard">Hard</span>
              </label>
            </div>
            <div class="color-picker" style="margin-top:10px;">
              <label class="color-option">
                <input type="radio" name="ai-color" value="white" checked />
                <span class="color-swatch color-white">♔</span>
                <span>White</span>
              </label>
              <label class="color-option">
                <input type="radio" name="ai-color" value="black" />
                <span class="color-swatch color-black">♚</span>
                <span>Black</span>
              </label>
              <label class="color-option">
                <input type="radio" name="ai-color" value="random" />
                <span class="color-swatch color-random">🎲</span>
                <span>Random</span>
              </label>
            </div>
            <button id="btn-play-ai" class="btn btn-primary btn-full" style="margin-top:14px;">Play AI</button>
          </div>
        </div>

        <!-- Footer -->
        <div class="lobby-footer">
          <p>♟ ChessPlay — Developed by Aniruddh Parmar</p>
        </div>
      </div>

      <!-- Profile Modal -->
      <div id="profile-modal" class="modal-overlay" style="display:none;">
        <div class="modal glass-panel profile-modal-content">
          <button id="btn-close-profile" class="btn-close-chat" style="position:absolute;top:16px;right:16px;">✕</button>
          <div class="profile-header">
            <div class="profile-avatar">👤</div>
            <h2 class="profile-name" id="profile-name">—</h2>
            <p class="profile-since" id="profile-since">Member since —</p>
          </div>
          <div class="profile-stats">
            <div class="stat-card">
              <span class="stat-value" id="stat-games">0</span>
              <span class="stat-label">Played</span>
            </div>
            <div class="stat-card stat-win">
              <span class="stat-value" id="stat-wins">0</span>
              <span class="stat-label">Wins</span>
            </div>
            <div class="stat-card stat-loss">
              <span class="stat-value" id="stat-losses">0</span>
              <span class="stat-label">Losses</span>
            </div>
            <div class="stat-card stat-draw">
              <span class="stat-value" id="stat-draws">0</span>
              <span class="stat-label">Draws</span>
            </div>
          </div>
          <div class="profile-winrate">
            <span class="winrate-label">Win Rate</span>
            <div class="winrate-bar">
              <div class="winrate-fill" id="winrate-fill" style="width:0%;">0%</div>
            </div>
          </div>
          <h3 class="panel-title" style="margin-top:20px;">Recent Games</h3>
          <div class="recent-games" id="recent-games">
            <p style="color:var(--text-muted);font-size:13px;text-align:center;">No games yet</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ============================================================
         SCREEN 3: WAITING ROOM (Show code, wait for opponent)
         ============================================================ -->
    <div id="waiting-screen" class="screen">
      <div class="waiting-container">
        <div class="glass-panel waiting-panel">
          <div class="waiting-icon">⏳</div>
          <h2 class="waiting-title">Waiting for Opponent</h2>
          <p class="waiting-desc">Share this room code with your friend:</p>
          <div class="room-code-display" id="room-code-display">------</div>
          <button id="btn-copy-code" class="btn btn-secondary btn-full">📋 Copy Code</button>
          <div id="copy-feedback" class="copy-feedback" style="display:none;">Copied!</div>
          <div class="waiting-dots">
            <span></span><span></span><span></span>
          </div>
          <button id="btn-back-lobby" class="btn btn-secondary btn-full" style="margin-top: 12px;">← Back to Lobby</button>
        </div>
      </div>
    </div>

    <!-- ============================================================
         SCREEN 4: GAME (The chess board)
         ============================================================ -->
    <div id="game-screen" class="screen">
      <!-- Header / Navigation -->
      <header id="site-header">
        <div class="header-inner">
          <div class="logo">
            <span class="logo-icon">♔</span>
            <span class="logo-text">ChessPlay</span>
          </div>
          <nav class="header-nav">
            <span class="room-code-badge" id="game-room-code">Room: ------</span>
            <span class="nav-badge" id="connection-status">
              <span class="status-dot"></span>
              <span class="connection-text">Connecting…</span>
            </span>
          </nav>
        </div>
      </header>

      <!-- Main Game Area -->
      <main id="game-area">
        <div class="game-container">

          <!-- Left Sidebar — Captured Pieces -->
          <aside class="sidebar sidebar-left">
            <div class="panel glass-panel">
              <h3 class="panel-title">Captured</h3>
              <div class="captured-section">
                <div class="captured-label">By White</div>
                <div class="captured-pieces" id="captured-by-white"></div>
              </div>
              <div class="captured-section">
                <div class="captured-label">By Black</div>
                <div class="captured-pieces" id="captured-by-black"></div>
              </div>
            </div>

            <!-- Board Theme Picker (in-game) -->
            <div class="panel glass-panel ingame-theme-panel">
              <h3 class="panel-title">🎨 Board</h3>
              <div class="ingame-theme-grid" id="ingame-theme-grid">
                <button class="ingame-theme-btn active" data-theme="classic" title="Classic Wood">
                  <div class="it-preview"><div class="it-sq" style="background:#f0d9b5;"></div><div class="it-sq" style="background:#b58863;"></div><div class="it-sq" style="background:#b58863;"></div><div class="it-sq" style="background:#f0d9b5;"></div></div>
                </button>
                <button class="ingame-theme-btn" data-theme="emerald" title="Emerald">
                  <div class="it-preview"><div class="it-sq" style="background:#eeeed2;"></div><div class="it-sq" style="background:#769656;"></div><div class="it-sq" style="background:#769656;"></div><div class="it-sq" style="background:#eeeed2;"></div></div>
                </button>
                <button class="ingame-theme-btn" data-theme="ice" title="Blue Ice">
                  <div class="it-preview"><div class="it-sq" style="background:#dee3e6;"></div><div class="it-sq" style="background:#8ca2ad;"></div><div class="it-sq" style="background:#8ca2ad;"></div><div class="it-sq" style="background:#dee3e6;"></div></div>
                </button>
                <button class="ingame-theme-btn" data-theme="tournament" title="Tournament">
                  <div class="it-preview"><div class="it-sq" style="background:#e8e0c8;"></div><div class="it-sq" style="background:#3a7d44;"></div><div class="it-sq" style="background:#3a7d44;"></div><div class="it-sq" style="background:#e8e0c8;"></div></div>
                </button>
                <button class="ingame-theme-btn" data-theme="marble" title="Marble">
                  <div class="it-preview"><div class="it-sq" style="background:#f5f0e1;"></div><div class="it-sq" style="background:#6e6658;"></div><div class="it-sq" style="background:#6e6658;"></div><div class="it-sq" style="background:#f5f0e1;"></div></div>
                </button>
                <button class="ingame-theme-btn" data-theme="walnut" title="Walnut">
                  <div class="it-preview"><div class="it-sq" style="background:#e6cba1;"></div><div class="it-sq" style="background:#7b4e2a;"></div><div class="it-sq" style="background:#7b4e2a;"></div><div class="it-sq" style="background:#e6cba1;"></div></div>
                </button>
              </div>
            </div>
          </aside>

          <!-- Center — Board + Players -->
          <section class="board-section">
            <!-- Opponent (top) -->
            <div class="player-bar player-bar-top" id="player-top">
              <div class="player-avatar">♚</div>
              <div class="player-info">
                <span class="player-name">Black</span>
                <span class="player-status">Waiting…</span>
              </div>
              <div class="player-timer" id="timer-top">--:--</div>
            </div>

            <!-- Game Status Banner -->
            <div class="game-status-banner" id="game-status" style="display:none;">
              <span class="status-text" id="status-text"></span>
            </div>

            <!-- Chess Board -->
            <div class="board-wrapper">
              <div class="board-coords board-coords-files">
                <span>a</span><span>b</span><span>c</span><span>d</span><span>e</span><span>f</span><span>g</span><span>h</span>
              </div>
              <div class="board-coords board-coords-ranks">
                <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
              </div>
              <div class="chessboard" id="chessboard">
                <!-- Board squares rendered by JS -->
              </div>
            </div>

            <!-- Current Player (bottom) -->
            <div class="player-bar player-bar-bottom" id="player-bottom">
              <div class="player-avatar">♔</div>
              <div class="player-info">
                <span class="player-name">White</span>
                <span class="player-status">Waiting…</span>
              </div>
              <div class="player-timer" id="timer-bottom">--:--</div>
            </div>
          </section>

          <!-- Right Sidebar — Moves + Controls + Chat -->
          <aside class="sidebar sidebar-right">
            <!-- Move History Table -->
            <div class="panel glass-panel moves-panel">
              <h3 class="panel-title">📋 Moves</h3>
              <div class="move-list" id="move-list">
                <div class="move-placeholder">No moves yet</div>
              </div>
            </div>

            <!-- Chat Panel -->
            <div class="panel glass-panel chat-panel" id="chat-panel">
              <div class="chat-header">
                <h3 class="panel-title">💬 Chat</h3>
                <span class="chat-online-dot"></span>
              </div>
              <div class="chat-messages" id="chat-messages">
                <div class="chat-placeholder" id="chat-placeholder">
                  <span class="chat-placeholder-icon">💬</span>
                  <span>No messages yet</span>
                  <span class="chat-placeholder-hint">Say hello to your opponent!</span>
                </div>
              </div>
              <div class="chat-typing" id="chat-typing" style="display:none;">
                <span class="typing-dots"><span></span><span></span><span></span></span>
                <span class="typing-text" id="typing-text">Opponent is typing…</span>
              </div>
              <div class="chat-quick-emojis">
                <button class="emoji-btn" data-emoji="👍">👍</button>
                <button class="emoji-btn" data-emoji="😂">😂</button>
                <button class="emoji-btn" data-emoji="🔥">🔥</button>
                <button class="emoji-btn" data-emoji="😮">😮</button>
                <button class="emoji-btn" data-emoji="👏">👏</button>
                <button class="emoji-btn" data-emoji="💪">💪</button>
              </div>
              <div class="chat-input-area">
                <input type="text" id="chat-input" class="chat-input" placeholder="Type a message…" maxlength="200" autocomplete="off" />
                <button id="btn-send-chat" class="btn btn-chat-send" title="Send">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
              </div>
            </div>

            <!-- Game Controls -->
            <div class="panel glass-panel game-controls">
              <button class="btn btn-accent" id="btn-new-game" title="Rematch">
                <span>↻</span> Rematch
              </button>
              <button class="btn btn-danger" id="btn-resign" title="Resign">
                <span>🏳️</span> Resign
              </button>
              <button class="btn btn-secondary" id="btn-leave-game" title="Leave Game">
                <span>←</span> Leave
              </button>
            </div>
          </aside>

          <!-- Mobile Chat Toggle -->
          <button id="btn-chat-toggle" class="chat-toggle-btn" title="Open Chat">💬</button>

        </div>
      </main>

      <!-- Footer -->
      <footer id="site-footer">
        <p>Developed by Aniruddh Parmar</p>
      </footer>
    </div>

    <!-- ============================================================
         GAME OVER MODAL — Premium Victory Celebration
         ============================================================ -->
    <canvas id="confetti-canvas"></canvas>
    <div id="gameover-modal" class="modal-overlay" style="display:none;">
      <div class="modal glass-panel gameover-modal-content" id="gameover-panel">
        <div class="victory-glow" id="victory-glow"></div>
        <div class="modal-crown" id="modal-crown">
          <span class="modal-icon" id="modal-icon">🏆</span>
        </div>
        <h2 class="modal-title" id="modal-title">Game Over</h2>
        <p class="modal-message" id="modal-message">Checkmate!</p>
        <p class="modal-quote" id="modal-quote"></p>
        <div class="modal-game-stats" id="modal-game-stats">
          <div class="modal-stat">
            <span class="modal-stat-value" id="modal-stat-moves">0</span>
            <span class="modal-stat-label">Moves</span>
          </div>
          <div class="modal-stat">
            <span class="modal-stat-value" id="modal-stat-duration">0:00</span>
            <span class="modal-stat-label">Duration</span>
          </div>
        </div>
        <div class="modal-actions">
          <button id="btn-modal-rematch" class="btn btn-primary">↻ Play Again</button>
          <button id="btn-modal-lobby" class="btn btn-secondary">← Back to Lobby</button>
        </div>
      </div>
    </div>

    <!-- ============================================================
         MOBILE CHAT OVERLAY (shown on smaller screens)
         ============================================================ -->
    <div id="chat-overlay" class="chat-overlay">
      <div class="chat-panel-mobile">
        <div class="chat-overlay-header">
          <h3 class="panel-title">💬 Chat</h3>
          <button id="btn-close-chat" class="btn-close-chat" title="Close Chat">✕</button>
        </div>
        <div class="chat-messages" id="chat-messages-mobile"></div>
        <div class="chat-typing" id="chat-typing-mobile" style="display:none;">
          <span class="typing-dots"><span></span><span></span><span></span></span>
          <span class="typing-text">Opponent is typing…</span>
        </div>
        <div class="chat-quick-emojis">
          <button class="emoji-btn emoji-btn-mobile" data-emoji="👍">👍</button>
          <button class="emoji-btn emoji-btn-mobile" data-emoji="😂">😂</button>
          <button class="emoji-btn emoji-btn-mobile" data-emoji="🔥">🔥</button>
          <button class="emoji-btn emoji-btn-mobile" data-emoji="😮">😮</button>
          <button class="emoji-btn emoji-btn-mobile" data-emoji="👏">👏</button>
          <button class="emoji-btn emoji-btn-mobile" data-emoji="💪">💪</button>
        </div>
        <div class="chat-input-area">
          <input type="text" id="chat-input-mobile" class="chat-input" placeholder="Type a message…" maxlength="200" autocomplete="off" />
          <button id="btn-send-chat-mobile" class="btn btn-chat-send" title="Send">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Scripts -->
    <script
      src="https://cdn.socket.io/4.8.3/socket.io.min.js"
      integrity="sha384-kzavj5fiMwLKzzD1f8S7TeoVIEi7uKHvbTA3ueZkrzYq75pNQUiUi6Dy98Q3fxb0"
      crossorigin="anonymous"
    ></script>
    <script type="module" src="/js/chessgame.js"></script>

  </body>
</html>
